# Copy this file to .env and fill in your values (never commit .env to git).
#
# Docker Compose: LANGFLOW_API_URL must use the service name "langflow".
# Local uvicorn without Docker: use http://127.0.0.1:7860/api/v1/run

LANGFLOW_API_URL=http://langflow:7860/api/v1/run
LANGFLOW_FLOW_ID=your-flow-uuid-from-langflow-ui
LANGFLOW_API_KEY=your-langflow-api-key
MISTRAL_API_KEY=your-mistral-api-key
REQUEST_TIMEOUT=120.0

# Optional: absolute path to frontend if auto-detection fails
# FRONTEND_DIR=
